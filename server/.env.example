# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/thevia

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Storage: "local" or "r2"
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# R2/S3 (when STORAGE_TYPE=r2)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=thevia-definitions

# Rate Limiting
RATE_LIMIT_GENERAL=30
RATE_LIMIT_UPLOAD_DAILY=10
